# Copy this to .env and fill in real values before deploying

# Server
PORT=3000
NODE_ENV=production
DATA_SOURCE=simulator

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Staff users (JSON array — change passwords in production!)
STAFF_USERS=[{"id":"admin1","name":"Control Room","role":"admin","password":"admin123"},{"id":"ops1","name":"Ops Manager","role":"ops","password":"ops123"},{"id":"steward1","name":"Steward Khan","role":"steward","password":"steward123"}]

# Redis (optional — falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379

# Gemini AI — get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Demo mode (returns OTP in response body for testing)
DEMO_MODE=true

# App URLs (update to your deployed domain)
NEXT_PUBLIC_API_URL=https://your-app.railway.app
NEXT_PUBLIC_FAN_APP_URL=https://your-app.railway.app
